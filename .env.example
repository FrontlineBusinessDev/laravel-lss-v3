APP_NAME="LSS Admin"
APP_ENV=local
APP_KEY=base64:1lkuH5xMyFiCPteJZKiUxOD62+MutkLje3EfrUbPDEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
INERTIA_SSR_ENABLED=false
INERTIA_SSR_ENSURE_BUNDLE_EXISTS=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Bulk (multi-recipient) ticket notifications are pushed to this queue and drained
# by the scheduled `queue:work` in routes/console.php, which the cron runs via
# schedule:run. Requires the `jobs`/`failed_jobs` tables (php artisan migrate).

# Shared secret for the external cron endpoint (GET /cron/{token} -> schedule:run).
# Generate one with: php artisan tinker --execute="echo \Illuminate\Support\Str::random(48);"
CRON_SECRET=

# Facebook App ID for the public register share card's fb:app_id meta tag.
# Get one at developers.facebook.com. Leave empty to omit the (non-blocking) tag.
FACEBOOK_APP_ID=

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Set MAIL_MAILER=smtp (with real host/credentials below) to actually transmit
# mail. The `log` default writes messages to storage/logs and sends NOTHING —
# useful for local dev, a silent black hole in production.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Example PRODUCTION SMTP block (Hostinger or similar) — uncomment and fill in
# real values, and set MAIL_MAILER=smtp above. Port 465 needs
# MAIL_ENCRYPTION=ssl and MAIL_SCHEME=smtps; port 587 needs
# MAIL_ENCRYPTION=tls. See docs/production-email-cron-checklist.md.
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.hostinger.com
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
# MAIL_USERNAME=contact@frontlinebusiness.com.ph
# MAIL_PASSWORD=
# MAIL_FROM_ADDRESS="contact@frontlinebusiness.com.ph"
# MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# DigitalOcean Spaces — ticket attachments live here (see config/filesystems.php
# 'spaces' disk). Objects are PRIVATE by default and served via presigned URLs;
# only files flagged is_public_seo are stored public-read for crawler indexing.
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=sgp1
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
# Public base URL for is_public_seo objects (virtual-hosted style, no trailing
# slash), e.g. https://your-bucket.sgp1.digitaloceanspaces.com
DO_SPACES_URL=
# Optional: namespace all objects under a folder in a shared bucket.
DO_SPACES_ROOT=

VITE_APP_NAME="${APP_NAME}"
VITE_APP_HEADER_NAME="FRONTLINE"
OCTANE_SERVER=frankenphp